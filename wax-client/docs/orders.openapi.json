{
  "openapi": "3.0.3",
  "info": {
    "title": "WAX API - Order",
    "description": "Endpoints for order management: listing orders with infinite pagination, retrieving order details, and creating new orders from the active basket.",
    "version": "1.0.0",
    "contact": {
      "name": "WAX Backend Team"
    }
  },
  "servers": [
    {
      "url": "https://localhost:5007",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Order",
      "description": "Order operations: listing, detail retrieval, and creation"
    }
  ],
  "paths": {
    "/api/Order": {
      "get": {
        "tags": ["Order"],
        "summary": "List orders",
        "description": "Returns a paginated list of orders for the authenticated user using infinite scroll pagination. Supports filtering by status and date range.",
        "operationId": "Order_GetOrders",
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "description": "Cursor for infinite pagination. Pass the cursor value returned by the previous page to fetch the next set of results.",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2026-04-01T00:00:00Z"
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of orders to return per page",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "example": 10
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter orders by status (e.g. 'Pending', 'PaymentReceived', 'PaymentFailed')",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "PaymentReceived"
          },
          {
            "name": "startDate",
            "in": "query",
            "description": "Return orders created before this date (defaults to current UTC time)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "example": "2026-04-19T00:00:00Z"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of orders retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InfinityPagedListOrderDto"
                },
                "example": {
                  "items": [
                    {
                      "id": "order-001",
                      "buyerEmail": "user@example.com",
                      "billingAddress": {
                        "name": "Juan De La Torre",
                        "line1": "Av. Siempre Viva 742",
                        "line2": null,
                        "city": "Bogotá",
                        "state": "Cundinamarca",
                        "postalCode": "110111",
                        "country": "CO"
                      },
                      "orderItems": [
                        {
                          "productId": "prod-abc-123",
                          "name": "Technics SL-1200",
                          "price": 120000,
                          "quantity": 1
                        }
                      ],
                      "subtotal": 120000,
                      "deliveryFee": 5000,
                      "discount": 0,
                      "total": 125000,
                      "orderStatus": "PaymentReceived",
                      "paymentSummary": {
                        "last4": 4242,
                        "brand": "visa",
                        "expMonth": 12,
                        "expYear": 2027
                      },
                      "createAt": "2026-04-10T14:30:00Z",
                      "updatedAt": null
                    }
                  ],
                  "nextCursor": "2026-04-10T14:30:00Z",
                  "hasMore": false
                }
              }
            }
          },
          "401": {
            "description": "User is not authenticated"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      },
      "post": {
        "tags": ["Order"],
        "summary": "Create an order",
        "description": "Creates a new order from the items in the current basket. The basket is identified via a session cookie. The basket is cleared after the order is successfully created.",
        "operationId": "Order_CreateOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderDto"
              },
              "example": {
                "paymentSummary": {
                  "last4": 4242,
                  "brand": "visa",
                  "exp_month": 12,
                  "exp_year": 2027
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDto"
                }
              }
            }
          },
          "400": {
            "description": "Basket is empty or order creation failed"
          },
          "401": {
            "description": "User is not authenticated"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    },
    "/api/Order/{id}": {
      "get": {
        "tags": ["Order"],
        "summary": "Get order details",
        "description": "Returns the full details of a specific order by its identifier.",
        "operationId": "Order_GetOrderDetails",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Unique identifier of the order",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "order-001"
          }
        ],
        "responses": {
          "200": {
            "description": "Order details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderDto"
                },
                "example": {
                  "id": "order-001",
                  "buyerEmail": "user@example.com",
                  "billingAddress": {
                    "name": "Juan De La Torre",
                    "line1": "Av. Siempre Viva 742",
                    "line2": null,
                    "city": "Bogotá",
                    "state": "Cundinamarca",
                    "postalCode": "110111",
                    "country": "CO"
                  },
                  "orderItems": [
                    {
                      "productId": "prod-abc-123",
                      "name": "Technics SL-1200",
                      "price": 120000,
                      "quantity": 1
                    }
                  ],
                  "subtotal": 120000,
                  "deliveryFee": 5000,
                  "discount": 0,
                  "total": 125000,
                  "orderStatus": "PaymentReceived",
                  "paymentSummary": {
                    "last4": 4242,
                    "brand": "visa",
                    "expMonth": 12,
                    "expYear": 2027
                  },
                  "createAt": "2026-04-10T14:30:00Z",
                  "updatedAt": null
                }
              }
            }
          },
          "401": {
            "description": "User is not authenticated"
          },
          "404": {
            "description": "Order not found"
          }
        },
        "security": [
          {
            "cookieAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "OrderDto": {
        "type": "object",
        "description": "Full order representation",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique order identifier",
            "example": "order-001"
          },
          "buyerEmail": {
            "type": "string",
            "format": "email",
            "description": "Email of the user who placed the order",
            "example": "user@example.com"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/BillingAddressDto"
          },
          "orderItems": {
            "type": "array",
            "description": "List of items included in the order",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          },
          "subtotal": {
            "type": "integer",
            "format": "int64",
            "description": "Sum of all item prices in cents before fees and discounts",
            "example": 120000
          },
          "deliveryFee": {
            "type": "integer",
            "format": "int64",
            "description": "Delivery fee in cents",
            "example": 5000
          },
          "discount": {
            "type": "integer",
            "format": "int64",
            "description": "Discount amount in cents",
            "example": 0
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Final total amount in cents (subtotal + deliveryFee - discount)",
            "example": 125000
          },
          "orderStatus": {
            "type": "string",
            "description": "Current status of the order",
            "enum": ["Pending", "PaymentReceived", "PaymentFailed"],
            "example": "PaymentReceived"
          },
          "paymentSummary": {
            "$ref": "#/components/schemas/PaymentSummaryDto"
          },
          "createAt": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time when the order was created (UTC)",
            "example": "2026-04-10T14:30:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Date and time of the last update (UTC). Null if never updated.",
            "example": null
          }
        }
      },
      "OrderItemDto": {
        "type": "object",
        "description": "A single item within an order",
        "properties": {
          "productId": {
            "type": "string",
            "description": "Unique identifier of the product",
            "example": "prod-abc-123"
          },
          "name": {
            "type": "string",
            "description": "Name of the product at the time of purchase",
            "example": "Technics SL-1200"
          },
          "price": {
            "type": "integer",
            "format": "int64",
            "description": "Unit price of the product in cents at the time of purchase",
            "example": 120000
          },
          "quantity": {
            "type": "integer",
            "description": "Number of units purchased",
            "example": 1
          }
        }
      },
      "BillingAddressDto": {
        "type": "object",
        "description": "Billing address associated with the order",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name on the billing address",
            "example": "Juan De La Torre"
          },
          "line1": {
            "type": "string",
            "description": "Primary address line",
            "example": "Av. Siempre Viva 742"
          },
          "line2": {
            "type": "string",
            "nullable": true,
            "description": "Secondary address line (optional)",
            "example": null
          },
          "city": {
            "type": "string",
            "description": "City",
            "example": "Bogotá"
          },
          "state": {
            "type": "string",
            "description": "State or department",
            "example": "Cundinamarca"
          },
          "postalCode": {
            "type": "string",
            "description": "Postal or ZIP code",
            "example": "110111"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code",
            "example": "CO"
          }
        }
      },
      "PaymentSummaryDto": {
        "type": "object",
        "description": "Summary of the payment method used for the order",
        "properties": {
          "last4": {
            "type": "integer",
            "description": "Last 4 digits of the card used",
            "example": 4242
          },
          "brand": {
            "type": "string",
            "description": "Card brand (e.g. visa, mastercard)",
            "example": "visa"
          },
          "expMonth": {
            "type": "integer",
            "description": "Card expiration month",
            "example": 12
          },
          "expYear": {
            "type": "integer",
            "description": "Card expiration year",
            "example": 2027
          }
        }
      },
      "CreateOrderDto": {
        "type": "object",
        "description": "Payload required to create a new order",
        "required": ["paymentSummary"],
        "properties": {
          "paymentSummary": {
            "$ref": "#/components/schemas/PaymentSummaryInput"
          }
        }
      },
      "PaymentSummaryInput": {
        "type": "object",
        "description": "Payment card summary provided at checkout",
        "required": ["brand", "last4", "exp_month", "exp_year"],
        "properties": {
          "last4": {
            "type": "integer",
            "description": "Last 4 digits of the card",
            "example": 4242
          },
          "brand": {
            "type": "string",
            "description": "Card brand",
            "example": "visa"
          },
          "exp_month": {
            "type": "integer",
            "description": "Card expiration month",
            "example": 12
          },
          "exp_year": {
            "type": "integer",
            "description": "Card expiration year",
            "example": 2027
          }
        }
      },
      "InfinityPagedListOrderDto": {
        "type": "object",
        "description": "Infinite-scroll paginated list of orders",
        "properties": {
          "items": {
            "type": "array",
            "description": "List of orders in the current page",
            "items": {
              "$ref": "#/components/schemas/OrderDto"
            }
          },
          "nextCursor": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Cursor value to pass in the next request to fetch the following page. Null if there are no more results.",
            "example": "2026-04-10T14:30:00Z"
          },
          "hasMore": {
            "type": "boolean",
            "description": "Indicates whether there are more results beyond the current page",
            "example": false
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": ".AspNetCore.Identity.Application",
        "description": "ASP.NET Identity authentication cookie. Obtained via POST /api/login?useCookies=true."
      }
    }
  }
}
